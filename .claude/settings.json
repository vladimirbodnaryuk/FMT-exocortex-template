{
  "hooks": {
    "UserPromptSubmit": [
      {
        "description": "WP Gate: напоминание проверить РП перед началом работы",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/wp-gate-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "description": "Напоминание о верификации после загрузки протокола",
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protocol-completion-reminder.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "description": "Checkpoint: сохранить контекст перед компрессией",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precompact-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
